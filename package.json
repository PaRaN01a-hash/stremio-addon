{
  "name": "stremio-personal-addon",
  "version": "1.0.0",
  "description": "Personal Stremio addon with TorBox debrid, Jackett scraping, HTTP fallback, and Redis caching",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint src --ext .ts",
    "dev:local": "REDIS_DISABLED=true PORT=6001 ts-node-dev --respawn --transpile-only src/index.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.0",
    "ioredis": "^5.3.2",
    "stremio-addon-sdk": "^1.6.10",
    "xml2js": "^0.6.2",
    "p-limit": "^4.0.0",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/xml2js": "^0.4.14",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.3.2",
    "ts-node-dev": "^2.0.0",
    "eslint": "^8.54.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0"
  }
}
