# ─── Server ───────────────────────────────────────────────
PORT=7000
ADDON_NAME="My Personal Addon"
ADDON_ID="com.personal.stremio-addon"
ADDON_VERSION="1.0.0"

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# Cache TTLs (seconds)
CACHE_TTL_STREAMS=1800        # 30 min for stream results
CACHE_TTL_TORRENT=3600        # 1 hour for torrent search results
CACHE_TTL_DEBRID=86400        # 24 hours for debrid availability
CACHE_TTL_HTTP=900            # 15 min for HTTP fallback results

# ─── TorBox ───────────────────────────────────────────────
TORBOX_API_KEY=your_torbox_api_key_here
TORBOX_API_URL=https://api.torbox.app/v1

# Auto-cache: automatically send uncached torrents to TorBox
TORBOX_AUTO_CACHE=true
# Max concurrent auto-cache requests
TORBOX_AUTO_CACHE_CONCURRENCY=3

# ─── Jackett ──────────────────────────────────────────────
JACKETT_URL=http://your-jackett-host:9117
JACKETT_API_KEY=your_jackett_api_key_here
# Comma-separated list of Jackett indexers to query (leave blank for all)
JACKETT_INDEXERS=
# Max results per indexer
JACKETT_MAX_RESULTS=20
# Timeout per Jackett search (ms)
JACKETT_TIMEOUT=8000

# ─── HTTP Fallback Providers ──────────────────────────────
ENABLE_VIDSRC=true
ENABLE_VIXSRC=true
ENABLE_SHOWBOX=false          # Requires FebBox cookie
FEBBOX_COOKIE=

# ─── TMDB ─────────────────────────────────────────────────
TMDB_API_KEY=your_tmdb_api_key_here

# ─── Background Worker ────────────────────────────────────
# Cron schedule for pre-caching popular/recent content
PRECACHE_CRON=0 */6 * * *     # Every 6 hours
PRECACHE_ENABLED=true
# How many titles to pre-cache per run
PRECACHE_LIMIT=50

# ─── Misc ─────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
